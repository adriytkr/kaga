{
  "compilerOptions": {
    "paths": {
      "~/*": ["./.vitepress/theme/*"],
      "~~/*": ["./*"],
      "~content/*": ["./content/*"]
    }
  },
  "include":[
    "./.vitepress/**/*.ts",
    "./.vitepress/**/*.vue",
    "**/*.ts",
    "**/*.vue",
    "**/*.md"
  ],
  "exclude": ["./node_modules/"],
  "vueCompilerOptions": {
    "vitePressExtensions": [".md"]
  }
}
