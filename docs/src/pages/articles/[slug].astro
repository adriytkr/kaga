---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';

import { idToSlug } from '@/utils/article';
import { ArticleService } from '@/services/ArticleService';
import ArticleLayout from '@layouts/ArticleLayout.astro';

export const getStaticPaths=(async()=>{
  const localizedArticles=await ArticleService.getAllArticlesByLocale('en');

  return localizedArticles.map(article=>{
    return{
      params:{
        slug:idToSlug(article.id),
      },
      props:{article},
    };
  });
}) satisfies GetStaticPaths;

const {article}=Astro.props;

const {Content}=await render(article);
---

<ArticleLayout title={article.data.title}>
  <Content/>
</ArticleLayout>
