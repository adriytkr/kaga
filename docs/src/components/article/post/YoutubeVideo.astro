---
import { YouTube } from '@astro-community/astro-embed-youtube';

import MediaWithCaption from './MediaWithCaption.astro';

interface Props{
  id:string;
  title:string;
}

const {id,title}=Astro.props;
---

<MediaWithCaption>
  <Fragment slot="media">
    <YouTube
      id={id}
      title={title}
      params="vq=hd720"
      class="w-full h-auto rounded-sm"
    />
  </Fragment>
  <slot></slot>
</MediaWithCaption>
