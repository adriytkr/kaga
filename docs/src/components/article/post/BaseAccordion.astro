<div class="group my-8" data-accordion>
  <button
    class="px-0 mb-2 bg-transparent flex gap-x-1 items-center text-muted"
    data-accordion-btn
  >
    <slot name="label"></slot>
  </button>
  <div
    class="grid overflow-hidden transition-all duration-400 ease-in-out grid-rows-[1fr] group-data-is-open:grid-rows-[0fr]"
  >
    <div class="min-h-0 text-gray-700 [&>*:first-child]:mt-0 [&>*:last-child]:mb-0 dark:text-gray-300">
      <slot></slot>
    </div>
  </div>
</div>

<script>
function setupAccordions(){
  const accordionEls=document.querySelectorAll('[data-accordion]') as NodeListOf<HTMLDivElement>;

  accordionEls.forEach(accordionEl=>{
    const btn=accordionEl.querySelector('[data-accordion-btn]') as HTMLButtonElement;

    btn.addEventListener('click',()=>{
      if(accordionEl.hasAttribute('data-is-open')){
        accordionEl.removeAttribute('data-is-open')
        return;
      }

      accordionEl.dataset.isOpen='true';
    });
  });
};

setupAccordions();
</script>
