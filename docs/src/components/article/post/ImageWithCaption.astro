---
import type { ImageMetadata } from 'astro';
import Image from 'astro/components/Image.astro';

import placeholderImage from '@assets/images/placeholder.webp';

import MediaWithCaption from './MediaWithCaption.astro';

interface Props{
  src?:ImageMetadata;
  alt?:string;
  zoomable:boolean;
}

const {src,alt,zoomable=true}=Astro.props;
---

<MediaWithCaption>
  <Fragment slot="media">
    <Image
      src={src??placeholderImage}
      alt={alt??''}
      class="w-full h-auto block object-cover rounded-sm"
      data-zoomable={zoomable}
      decoding="sync"
    />
  </Fragment>
  <slot></slot>
</MediaWithCaption>
