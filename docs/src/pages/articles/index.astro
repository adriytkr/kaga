---
import type {FilterLabel} from '@/types/t';

import {getArticlesByLocale} from '@utils/content';
import {convertStringToLocale} from '@utils/i18n';
import { ARTICLE_DIFFICULTIES } from '@utils/article';

import BaseLayout from '@layouts/BaseLayout.astro';
import SearchableGrid from '@components/article/index/SearchableGrid.vue';

const allArticles=await getArticlesByLocale(
  convertStringToLocale(Astro.currentLocale??'')??'en'
);

const uniqueCategories=[
  ...new Set(
    allArticles.flatMap((article)=>
      article.data.categories||[]
    )
  )
]

uniqueCategories.sort();

const t:FilterLabel={
  searchPlaceholder:'Search name, keywords, ...',
  difficultyTitle:'Choose difficulty',
  categoryTitle:'Choose categories',
  difficulties:{
    easy:'Easy',
    medium:'Medium',
    hard:'Hard',
  },
  empty:'No results found',
};
---

<BaseLayout title="Articles">
  <SearchableGrid
    articles={allArticles}
    categories={uniqueCategories}
    difficulties={ARTICLE_DIFFICULTIES}
    t={t}
    locale="en"
    client:load
  />
</BaseLayout>
