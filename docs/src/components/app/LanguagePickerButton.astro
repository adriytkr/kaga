---
import type { HTMLAttributes } from 'astro/types';

import type { Locale } from '@/types/i18n';
import { getAbsoluteUrlWithoutLocale } from '@/utils/i18n';

import LinkLocale from './LinkLocale.astro';

interface Props extends HTMLAttributes<'a'>{
  locale:Locale;
}

const {
  class:className,
  locale,
  ...props
}=Astro.props;

const sanitizedUrl=getAbsoluteUrlWithoutLocale(
  Astro.currentLocale as Locale,
  Astro.url.pathname,
);
---

<LinkLocale
  href={sanitizedUrl}
  class:list={[
    'px-6 py-2 text-muted block! transition-colors duration-200 hover:text-body hover:no-underline hover:bg-white',
    className,
  ]}
  activeClass="font-bold !text-body"
  locale={locale}
  isActive={locale===Astro.currentLocale}
  {...props}
>
  <slot></slot>
</LinkLocale>
